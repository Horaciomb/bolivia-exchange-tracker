# Copia este archivo a .env y rellena los valores reales.
# .env NUNCA se commitea (esta en .gitignore).

# ---------------------------------------------------------------------------
# DATABASE_URL — connection string DIRECTO de PostgreSQL (Supabase).
# Conexion via psycopg2 (NO se usa supabase-py ni SUPABASE_KEY).
# El proyecto vive en el esquema `fx` (ver sql/schema.sql).
#
# IMPORTANTE — IPv4 vs IPv6:
#   - La conexion DIRECTA (db.<ref>.supabase.co:5432) resuelve solo a IPv6.
#     Sirve en local si tu red tiene IPv6, pero NO funciona desde GitHub
#     Actions ni Render (sus runners no tienen salida IPv6 -> "Network is
#     unreachable").
#   - Para CI/CD (Actions) y para el deploy (Render) usa el POOLER de Supabase
#     (Supavisor), que es IPv4. Lo encuentras en:
#     Supabase Dashboard > Project Settings > Database > Connection string >
#     pestaña "Session pooler".
#
# Local (directo, IPv6):
#   postgresql://postgres:PASSWORD@db.<ref>.supabase.co:5432/postgres
#
# Actions / Render (pooler, IPv4) — nota el usuario `postgres.<ref>` y el host:
#   postgresql://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres

# Base URL de la fuente de datos (DolarApi Bolivia).
DOLARAPI_BASE_URL=https://bo.dolarapi.com
