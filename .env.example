# Copia este archivo a .env y rellena los valores reales.
# .env NUNCA se commitea (esta en .gitignore).

# Connection string de PostgreSQL en Supabase.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# Base URL de la fuente de datos (DolarApi Bolivia).
DOLARAPI_BASE_URL=https://bo.dolarapi.com
